{%- doc -%}
  Renders a wrapper section

  @param {section} section - The section object
  @param {string} children - The children of the section
{%- enddoc -%}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="section section--{{ section.settings.section_width }} color-{{ section.settings.color_scheme }}"
  data-testid="ui-test-section"

  {% if request.visual_preview_mode %}
    data-shopify-visual-preview
  {% endif %}

  style="
    {% if section.settings.section_height == 'custom' %}
      --section-min-height: {{ section.settings.section_height_custom }}svh;
    {% elsif section.settings.section_height == 'full-screen' %}
      --section-min-height: 100svh;
    {% elsif section.settings.section_height != '' %}
      --section-min-height: var(--section-height-{{ section.settings.section_height }});
    {% endif %}

    {% if section.settings.section_height != '' %}
     --section-preview-height: 600px;
     {% endif %}
  "
>
  <div class="custom-section-background">
    {% liquid
      assign bg_media = section.settings.background_media
      assign bg_image = section.settings.background_image
      assign bg_image_position = section.settings.background_image_position
      if section.settings.multicolumn_layout and section.settings.multicolumn_background_image != blank
        assign bg_media = 'image'
        assign bg_image = section.settings.multicolumn_background_image
        assign bg_image_position = section.settings.multicolumn_background_image_position
      endif
    %}
    {% render 'background-media',
      background_media: bg_media,
      background_video: section.settings.video,
      background_video_position: section.settings.video_position,
      background_image: bg_image,
      background_image_position: bg_image_position
    %}
  </div>

  <div
    class="border-style custom-section-content"
    style="{% render 'border-override', settings: section.settings %}"
  >
    {% if section.settings.toggle_overlay %}
      {% render 'overlay', settings: section.settings, layer: '0' %}
    {% endif %}

    {% liquid
      assign scroll_reveal_active = false
      if request.visual_preview_mode == false
        if section.settings.multicolumn_layout or section.settings.scroll_reveal_blocks
          assign scroll_reveal_active = true
        endif
      endif
      assign scroll_reveal_motion = 'slide_up'
      if scroll_reveal_active and section.settings.multicolumn_layout == false
        assign section_editor_name = section.name | strip
        assign rich_text_sections_fade_motion = false
        if section_editor_name == 't:names.rich_text_section'
          assign rich_text_sections_fade_motion = true
        elsif section_editor_name != blank and section_editor_name != 't:names.section'
          assign section_editor_name_downcase = section_editor_name | downcase
          if section_editor_name_downcase == 'rich text'
            assign rich_text_sections_fade_motion = true
          endif
        endif
        if rich_text_sections_fade_motion or section.settings.scroll_reveal_style == 'fade'
          assign scroll_reveal_motion = 'fade'
        endif
      endif
    %}
    <div
      class="
        spacing-style
        layout-panel-flex
        layout-panel-flex--{{ section.settings.content_direction }}
        section-content-wrapper
        {% if section.settings.vertical_on_mobile %} mobile-column{% endif %}
      "
      style="
        {% render 'layout-panel-style', settings: section.settings %}
        {% render 'spacing-style', settings: section.settings %}
      "
      data-testid="section-content"
      {% if scroll_reveal_active %}
        data-scroll-block-reveal
        {% if scroll_reveal_motion == 'fade' %}
          data-scroll-reveal-motion="fade"
        {% endif %}
      {% endif %}
    >
      {{ children }}
    </div>
  </div>
</div>

{% stylesheet %}
  .section-wrapper {
    --section-height-offset: 0px;
  }

  .section[data-shopify-visual-preview] {
    min-height: var(--section-preview-height);
    padding-top: 0;
  }

  .section[data-shopify-visual-preview] .custom-section-background {
    display: none;
  }

  body:has(> #header-group > .header-section > #header-component[transparent]):not(
      :has(> #header-group > .header-section + .shopify-section)
    )
    > main
    > .section-wrapper:first-child {
    --section-height-offset: var(--header-group-height, 0);
  }

  .custom-section-background {
    grid-column: 1 / -1;
  }

  .custom-section-content {
    z-index: var(--layer-flat);
  }

  [data-scroll-block-reveal]:not([data-scroll-reveal-uses]) > * {
    opacity: 0;
    transform: translate3d(0, 1rem, 0);
    transition:
      opacity 0.65s var(--animation-timing-fade-in, cubic-bezier(0.16, 1, 0.3, 1)),
      transform 0.65s var(--animation-timing-fade-in, cubic-bezier(0.16, 1, 0.3, 1));
  }

  [data-scroll-block-reveal]:not([data-scroll-reveal-uses]) > *:nth-child(1) {
    transition-delay: 0s;
  }
  [data-scroll-block-reveal]:not([data-scroll-reveal-uses]) > *:nth-child(2) {
    transition-delay: 0.05s;
  }
  [data-scroll-block-reveal]:not([data-scroll-reveal-uses]) > *:nth-child(3) {
    transition-delay: 0.1s;
  }
  [data-scroll-block-reveal]:not([data-scroll-reveal-uses]) > *:nth-child(4) {
    transition-delay: 0.15s;
  }
  [data-scroll-block-reveal]:not([data-scroll-reveal-uses]) > *:nth-child(5) {
    transition-delay: 0.2s;
  }
  [data-scroll-block-reveal]:not([data-scroll-reveal-uses]) > *:nth-child(6) {
    transition-delay: 0.25s;
  }
  [data-scroll-block-reveal]:not([data-scroll-reveal-uses]) > *:nth-child(7) {
    transition-delay: 0.3s;
  }
  [data-scroll-block-reveal]:not([data-scroll-reveal-uses]) > *:nth-child(n + 8) {
    transition-delay: 0.35s;
  }

  [data-scroll-block-reveal]:not([data-scroll-reveal-uses]) > *.scroll-block-reveal--visible {
    opacity: 1;
    transform: translate3d(0, 0, 0);
  }

  [data-scroll-block-reveal][data-scroll-reveal-motion='fade']:not([data-scroll-reveal-uses]) > * {
    transform: none;
    transition: opacity 0.65s var(--animation-timing-fade-in, cubic-bezier(0.16, 1, 0.3, 1));
  }

  [data-scroll-block-reveal][data-scroll-reveal-motion='fade']:not([data-scroll-reveal-uses])
    > *.scroll-block-reveal--visible {
    transform: none;
  }

  @media (prefers-reduced-motion: reduce) {
    [data-scroll-block-reveal]:not([data-scroll-reveal-uses]) > * {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
{% endstylesheet %}

{% if request.visual_preview_mode == false %}
  {% if scroll_reveal_active %}
    <script src="{{ 'scroll-block-reveal.js' | asset_url }}" defer></script>
  {% endif %}
{% endif %}
