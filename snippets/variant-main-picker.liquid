            assign opt_handle = product_option.name | handleize
            assign opt_is_size = false
            if opt_handle == 'size'
              assign opt_is_size = true
            endif
            assign opt_is_color = false
            if opt_handle == 'color'
              assign opt_is_color = true
            endif
            if opt_handle == 'colour'
              assign opt_is_color = true
            endif
            assign should_render = false
            if swap_second == 'size'
              if opt_is_size
                assign should_render = true
              endif
            endif
            if swap_second == 'color'
              if opt_is_color
                assign should_render = true
              endif
            endif
          -%}
          {%- if should_render -%}
            {%- liquid
              assign row_divider_top = apply_divider_top
              assign apply_divider_top = false
              assign swatch_count = product_option.values | map: 'swatch' | compact | size
              assign variant_style = block_settings.variant_style
              assign option_position_index0 = product_option.position | minus: 1
              assign option_id_attribute = ''

