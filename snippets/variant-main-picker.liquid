              </div>
            {%- elsif variant_style == 'swatch' or block_settings.variant_style == 'buttons' -%}
              {% liquid
                assign fieldset_ordinal = fieldset_ordinal | plus: 1
              %}
              {%- assign fieldset_index = option_position_index0 -%}
              <fieldset
                class="variant-option variant-option--buttons{% if opt_is_size %} variant-option--size{% endif %}{% if variant_style == 'swatch' %} variant-option--swatches{% else %} variant-option--{{ settings.variant_button_width }}{% endif %}{% if row_divider_top %} variant-option--divider-top{% endif %}"
                data-fieldset-index="{{ fieldset_index }}"
                ref="fieldsets[]"
                {{ option_id_attribute }}
              >
                <legend>
                  {{ product_option.name | escape -}}
                  {%- if variant_style == 'swatch' -%}
                    <span class="variant-option__swatch-value">{{ product_option.selected_value }}</span>
                  {%- endif %}
              {%- liquid
                assign is_size_option = false
                assign opt_handle_for_legend = product_option.name | handleize
                if opt_handle_for_legend == 'size'
                  assign is_size_option = true
                endif
              -%}
              {%- if is_size_option and block_settings.size_guide_image != blank -%}
                <dialog-component class="variant-size-guide">
                  <button
                    type="button"
                    on:click="/showDialog"
                    class="button button-unstyled variant-size-guide__link"
                  >
                    {{- block_settings.size_guide_label | default: 'Size Guide' -}}
                  </button>
                  <dialog
                    ref="dialog"
                    class="variant-size-guide__dialog dialog-modal color-{{ settings.popover_color_scheme }}"
                    scroll-lock
                    aria-label="{{ block_settings.size_guide_label | default: 'Size Guide' | escape }}"
                  >
                    <div class="variant-size-guide__content">
                      {{-
                        block_settings.size_guide_image
                        | image_url: width: 1600
                        | image_tag: loading: 'lazy'
                      -}}
                    </div>
                    <button
                      ref="closeButton"
                      on:click="/closeDialog"
                      class="button button-unstyled close-button variant-size-guide__close"
                      aria-label="{{ 'accessibility.close_dialog' | t }}"
                    >
                      {{- 'icon-close.svg' | inline_asset_content -}}
                    </button>
                  </dialog>
                </dialog-component>
              {%- endif -%}
                </legend>
                {%- for product_option_value in product_option.values -%}
