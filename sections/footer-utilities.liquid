

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="section section--{{ section.settings.section_width }} color-{{ section.settings.color_scheme }}"
  {{ section.shopify_attributes }}
>
  <div
    class="utilities utilities--direction-{{ section.settings.layout_direction | default: 'horizontal' }} utilities--blocks-{{ section.blocks.size }} spacing-style"
    style="{% render 'spacing-style', settings: section.settings %} --border-width: {{ section.settings.divider_thickness }}px; --gap: {{ section.settings.gap }}px;"
    data-testid="footer-utilities"
    {% if request.visual_preview_mode == false and section.settings.scroll_reveal_blocks %}
      data-scroll-block-reveal
    {% endif %}
  >
    {% content_for 'blocks' %}
  </div>
</div>

{% stylesheet %}
  .utilities {
    width: 100%;
    gap: var(--gap);
    text-wrap: nowrap;
    border-top: var(--border-width) solid var(--color-border);
    color: var(--color-foreground-muted);
  }

  .utilities a {
    color: var(--color-foreground-muted);
  }

  .utilities--direction-vertical {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .utilities--direction-vertical > * {
    text-align: center;
  }

  .utilities--direction-horizontal {
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
  }

  .utilities--direction-horizontal > * {
    text-align: center;
  }

  @media screen and (min-width: 750px) {
    .utilities--direction-horizontal {
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      justify-content: center;
      align-items: center;
      text-align: left;
    }

    .utilities--direction-horizontal > * {
      text-align: left;
      justify-self: start;
    }

    .utilities--direction-horizontal.utilities--blocks-1 {
      grid-template-columns: 1fr;
      justify-content: start;
    }

    .utilities--direction-horizontal.utilities--blocks-1 > * {
      justify-self: start;
      text-align: left;
    }

    .utilities--direction-horizontal.utilities--blocks-2 {
      grid-template-columns: 1fr 1fr;
    }

    .utilities--direction-horizontal.utilities--blocks-2 > *:nth-child(2) {
      justify-self: end;
      text-align: right;
    }

    .utilities--direction-horizontal.utilities--blocks-3 {
      grid-template-columns: 1fr auto 1fr;
    }

    .utilities--direction-horizontal.utilities--blocks-3 > *:nth-child(2) {
      justify-self: center;
      text-align: center;
    }

    .utilities--direction-horizontal.utilities--blocks-3 > *:nth-child(3) {
      justify-self: end;
      text-align: right;
    }

    .utilities--direction-horizontal.utilities--blocks-4 {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }

    .utilities--direction-horizontal.utilities--blocks-4 > *:nth-child(2),
    .utilities--direction-horizontal.utilities--blocks-4 > *:nth-child(3) {
      justify-self: center;
      text-align: center;
    }

    .utilities--direction-horizontal.utilities--blocks-4 > *:nth-child(4) {
      justify-self: end;
      text-align: right;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.policies_and_links",
  "tag": "div",
  "class": "footer-utilities",
  "max_blocks": 4,
  "enabled_on": {
    "groups": ["footer"]
  },
  "settings": [
    {
      "type": "select",
      "id": "section_width",
      "label": "t:settings.width",
      "options": [
        {
          "value": "page-width",
          "label": "t:options.page"
        },
        {
          "value": "full-width",
          "label": "t:options.full"
        }
      ],
      "default": "page-width"
    },
    {
      "type": "select",
      "id": "layout_direction",
      "label": "t:settings.direction",
      "options": [
        {
          "value": "horizontal",
          "label": "t:options.horizontal"
        },
        {
          "value": "vertical",
          "label": "t:options.vertical"
        }
      ],
      "default": "horizontal"
    },
    {
      "type": "range",
      "id": "gap",
      "label": "t:settings.gap",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "divider_thickness",
      "label": "t:settings.divider_thickness",
      "min": 0,
      "max": 5,
      "step": 0.5,
      "unit": "px",
      "default": 1
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "checkbox",
      "id": "scroll_reveal_blocks",
      "label": "t:settings.scroll_reveal_blocks",
      "default": true,
      "info": "t:info.scroll_reveal_blocks"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 20
    }
  ],
  "blocks": [
    {
      "type": "footer-copyright"
    },
    {
      "type": "footer-policy-list"
    },
    {
      "type": "social-links"
    },
    {
      "type": "payment-icons"
    }
  ],
  "presets": [
    {
      "name": "t:names.policies_and_links",
      "category": "t:categories.footer",
      "blocks": {
        "copyright": {
          "type": "footer-copyright"
        },
        "policy_list": {
          "type": "footer-policy-list"
        },
        "social_icons": {
          "type": "social-links"
        },
        "payment_icons": {
          "type": "payment-icons",
          "settings": {
            "horizontal_alignment": "flex-end",
            "gap": 10,
            "padding-block-start": 0,
            "padding-block-end": 0,
            "padding-inline-start": 0,
            "padding-inline-end": 0
          }
        }
      },
      "block_order": ["copyright", "policy_list", "social_icons", "payment_icons"]
    }
  ]
}
{% endschema %}
