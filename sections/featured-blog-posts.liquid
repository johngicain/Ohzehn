

{% liquid
  assign max_items = section.settings.post_limit
  assign blog_post_tags = section.settings.blog_post_tags | strip
  assign blog_post_tags_array = blog_post_tags | split: ','
%}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>

<div
  class="
    section
    section--{{ section.settings.section_width }}
    color-{{ section.settings.color_scheme }}
    section-resource-list
    spacing-style
    gap-style
  "
  style="
    {%- render 'spacing-style', settings: section.settings -%}
    {%- render 'gap-style', value: section.settings.gap -%}
  "
  data-featured-blog-posts-section="{{ section.id }}"
>
  {% content_for 'block', id: 'static-blog-title', type: 'text', text: '<h3>{{ closest.blog.title }}</h3>', type_preset: 'rte' %}

  {% if section.settings.blog != blank and section.settings.blog.articles_count > 0 %}
    {% assign section_articles = section.settings.blog.articles %}
    {% assign onboarding_mode = false %}
  {% else %}
    {% assign section_articles = '' %}
    {% assign onboarding_mode = true %}
    {% for i in (1..max_items) %}
      {% assign section_articles = section_articles | append: ', ' %}
    {% endfor %}
    {% assign section_articles = section_articles | split: ',' %}
  {% endif %}

  {% if blog_post_tags != blank and onboarding_mode == false %}
    <div class="featured-blog-posts__filters" data-featured-blog-posts-filters>
      <button
        type="button"
        class="featured-blog-posts__filter-button is-active"
        data-featured-blog-posts-filter="all"
      >
        All
      </button>
      {% for tag in blog_post_tags_array %}
        {% assign tag_label = tag | strip %}
        {% if tag_label != blank %}
          <button
            type="button"
            class="featured-blog-posts__filter-button"
            data-featured-blog-posts-filter="{{ tag_label | downcase | escape }}"
          >
            {{ tag_label | escape }}
          </button>
        {% endif %}
      {% endfor %}
    </div>
  {% endif %}

  {% assign rendered_items = 0 %}
  {% capture list_items %}
    {% for article in section_articles %}
      {% assign should_render_article = true %}
      {% if onboarding_mode == false and blog_post_tags != blank %}
        {% assign should_render_article = false %}
        {% assign article_tags = article.tags | join: '||' | downcase %}
        {% assign article_tags = '||' | append: article_tags | append: '||' %}

        {% for tag in blog_post_tags_array %}
          {% assign normalized_tag = tag | strip | downcase %}
          {% if normalized_tag != blank %}
            {% assign search_tag = '||' | append: normalized_tag | append: '||' %}
            {% if article_tags contains search_tag %}
              {% assign should_render_article = true %}
              {% break %}
            {% endif %}
          {% endif %}
        {% endfor %}
      {% endif %}

      {% if should_render_article %}
        <div
          class="resource-list__item"
          data-blog-post-tags="{% if onboarding_mode == false %}{{ article.tags | join: ',' | downcase | escape }}{% endif %}"
        >
          {% content_for 'block', id: 'static-blog-post-card', type: '_featured-blog-posts-card', article: article, closest.article: article %}
        </div>
        {% assign rendered_items = rendered_items | plus: 1 %}
        {% if rendered_items < max_items %}
          <!--@list/split-->
        {% endif %}
      {% endif %}

      {% if rendered_items >= max_items %}
        {% break %}
      {% endif %}
    {% endfor %}
  {% endcapture %}

  {% liquid
    assign list_items_array = list_items | strip | split: '<!--@list/split-->'
  %}

  {% render 'resource-list',
    list_items: list_items,
    list_items_array: list_items_array,
    settings: section.settings,
    carousel_ref: 'featuredBlog',
    slide_count: rendered_items,
    content_type: 'articles',
    test_id: 'featured-blog-posts'
  %}
</div>

{% if section.settings.show_featured_image_border %}
  <style>
    [data-featured-blog-posts-section='{{ section.id }}'] .blog-post-featured-image__image {
      border: 1px solid rgb(var(--color-foreground-rgb) / 0.2);
    }
  </style>
{% endif %}

{% if blog_post_tags != blank and onboarding_mode == false %}
  <style>
    [data-featured-blog-posts-section='{{ section.id }}'] .featured-blog-posts__filters {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }

    [data-featured-blog-posts-section='{{ section.id }}'] .featured-blog-posts__filter-button {
      border: none;
      background: rgb(var(--color-foreground-rgb) / var(--opacity-5));
      color: inherit;
      padding: 7px 12px;
      border-radius: 1rem;
      cursor: pointer;
      font: inherit;
      font-size: 10px;
      font-weight: 700;
      line-height: 1.2;
      text-transform: uppercase;
      transition: all 0.2s ease;
    }

    [data-featured-blog-posts-section='{{ section.id }}'] .featured-blog-posts__filter-button.is-active,
    [data-featured-blog-posts-section='{{ section.id }}'] .featured-blog-posts__filter-button:hover {
      color: #ffffff;
      background: var(--color-foreground);
    }

    [data-featured-blog-posts-section='{{ section.id }}'] .resource-list__item {
      opacity: 1;
      transform: translateY(0);
      transition: all 0.2s ease;
    }

    [data-featured-blog-posts-section='{{ section.id }}'] .resource-list__item.is-filter-hidden {
      opacity: 0;
      transform: translateY(8px);
      pointer-events: none;
    }
  </style>

  <script>
    (() => {
      const section = document.querySelector("[data-featured-blog-posts-section='{{ section.id }}']");
      if (!section) return;
      const buttons = Array.from(section.querySelectorAll('[data-featured-blog-posts-filter]'));
      const items = Array.from(section.querySelectorAll('.resource-list__item'));
      if (!buttons.length || !items.length) return;
      const applyFilter = (filterTag) => {
        items.forEach((item) => {
          if (filterTag === 'all') {
            item.hidden = false;
            item.classList.remove('is-filter-hidden');
            return;
          }
          const itemTags = (item.getAttribute('data-blog-post-tags') || '')
            .split(',')
            .map((tag) => tag.trim().toLowerCase())
            .filter(Boolean);
          if (itemTags.includes(filterTag)) {
            item.hidden = false;
            item.classList.remove('is-filter-hidden');
            return;
          }
          item.classList.add('is-filter-hidden');
          window.setTimeout(() => {
            if (item.classList.contains('is-filter-hidden')) item.hidden = true;
          }, 200);
        });
      };
      buttons.forEach((button) => {
        button.addEventListener('click', () => {
          const filterTag = button.getAttribute('data-featured-blog-posts-filter') || 'all';
          buttons.forEach((filterButton) => filterButton.classList.remove('is-active'));
          button.classList.add('is-active');
          applyFilter(filterTag);
        });
      });
      applyFilter('all');
    })();
  </script>
{% endif %}

