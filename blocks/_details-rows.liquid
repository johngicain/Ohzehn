{%- liquid
  assign s = block.settings
  assign rows_class = 'details-rows spacing-style'
  if s.show_border
    assign rows_class = rows_class | append: ' details-rows--bordered'
  endif
-%}
{%- capture rows_style -%}
  {%- render 'spacing-style', settings: s -%}
  --rows-gap: {{ s.gap | default: 8 }}px;
  --rows-icon-size: {{ s.icon_size | default: 20 }}px;
{%- endcapture -%}

<ul
  class="{{ rows_class }}"
  role="list"
  style="{{ rows_style }}"
  {{ block.shopify_attributes }}
>
  {%- for index in (1..3) -%}
    {%- case index -%}
      {%- when 1 -%}
        {%- assign row_icon = s.row_1_icon -%}
        {%- assign row_text = s.row_1_text -%}
        {%- assign row_color = s.row_1_text_color -%}
        {%- assign row_font_size = s.row_1_font_size -%}
      {%- when 2 -%}
        {%- assign row_icon = s.row_2_icon -%}
        {%- assign row_text = s.row_2_text -%}
        {%- assign row_color = s.row_2_text_color -%}
        {%- assign row_font_size = s.row_2_font_size -%}
      {%- when 3 -%}
        {%- assign row_icon = s.row_3_icon -%}
        {%- assign row_text = s.row_3_text -%}
        {%- assign row_color = s.row_3_text_color -%}
        {%- assign row_font_size = s.row_3_font_size -%}
    {%- endcase -%}
    {%- capture row_style -%}
      {%- if row_color != blank %}color: {{ row_color }};{%- endif -%}
      {%- if row_font_size != blank %}font-size: {{ row_font_size }};{%- endif -%}
    {%- endcapture -%}
    {%- if row_text != blank or row_icon != 'none' -%}
      <li class="details-rows__row"{% if row_style != blank %} style="{{ row_style }}"{% endif %}>
        {%- if s.show_icons and row_icon != 'none' -%}
          <span class="details-rows__icon" aria-hidden="true">
            <svg
              class="details-rows__icon-svg icon-default"
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 20 20"
              focusable="false"
            >
              {%- render 'icon', icon: row_icon -%}
            </svg>
          </span>
        {%- endif -%}
        {%- if row_text != blank -%}
          <span class="details-rows__text">{{ row_text }}</span>
        {%- endif -%}
      </li>
    {%- endif -%}
  {%- endfor -%}
</ul>

{% stylesheet %}
  .details-rows {
    list-style: none;
    margin: 0;
    padding: 0;
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: var(--rows-gap, 8px);
  }

  .details-rows__row {
    display: flex;
    align-items: flex-start;
    gap: 12px;
  }

  .details-rows--bordered {
    padding: 12px;
    border: 1px solid rgb(var(--color-foreground-rgb) / 0.15);
    border-radius: var(--style-border-radius-inputs, 0);
  }

  .details-rows__icon {
    display: inline-flex;
    flex-shrink: 0;
    line-height: 0;
  }

  .details-rows__icon-svg {
    width: var(--rows-icon-size, 20px);
    height: var(--rows-icon-size, 20px);
    vertical-align: top;
  }

  .details-rows__text {
    flex: 1;
    min-width: 0;
  }
{% endstylesheet %}

