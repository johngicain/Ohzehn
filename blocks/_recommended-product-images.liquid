{%- liquid
  assign block_settings = block.settings
  assign max_products = block_settings.max_products | default: 4
  assign products_per_slide = 4
  assign fetch_limit = max_products | at_most: 10
  assign grid_columns = products_per_slide
  assign mobile_columns = 2
  assign heading_preset = block_settings.heading_preset | default: 'h5'
  if heading_preset == 'paragraph'
    assign heading_class = 'paragraph'
  elsif heading_preset != blank
    assign heading_class = heading_preset | append: ' ' | append: heading_preset
  endif
  assign displayed_product_count = 0
  assign page_count = 1

  if recommendations.performed or closest.product == blank
    if closest.product == blank
      for i in (1..max_products)
        assign products = products | append: ', '
        assign products = products | split: ','
      endfor
    elsif recommendations.performed and recommendations.products_count == 0
      if block_settings.recommendation_type == 'related'
        assign products = collections.all.products | reject: 'id', closest.product.id
      else
        assign products = null
      endif
    else
      assign products = recommendations.products
    endif

    if products != blank and products.size > 0
      if products.size > fetch_limit
        assign products = products | slice: 0, fetch_limit
      endif
      assign displayed_product_count = products.size | at_most: max_products
      if displayed_product_count < products.size
        assign products = products | slice: 0, displayed_product_count
      endif
      assign page_count = displayed_product_count | plus: products_per_slide | minus: 1 | divided_by: products_per_slide
    endif
  endif
-%}

<script
  src="{{ 'product-recommendations.js' | asset_url }}"
  type="module"
></script>
<script
  src="{{ 'recommended-product-images.js' | asset_url }}"
  type="module"
></script>

<product-recommendations
  id="recommended-product-images-{{ block.id }}"
  class="recommended-product-images"
  data-url="{{ routes.product_recommendations_url }}?limit={{ fetch_limit }}"
  data-section-id="{{ section.id }}"
  data-product-id="{{ closest.product.id }}"
  data-intent="{{ block_settings.recommendation_type }}"
  data-recommendations-performed="{{ recommendations.performed }}"
  data-hydration-key="recommended-product-images-{{ block.id }}"
  {% if request.visual_preview_mode %}
    data-shopify-editor-preview
  {% endif %}
  data-testid="recommended-product-images"
  {{ block.shopify_attributes }}
>
  <div
    class="recommended-product-images__inner spacing-style border-style"
    style="
      {% render 'spacing-style', settings: block_settings %}
      {% render 'border-override', settings: block_settings %}
      --recommended-images-gap: {{ block_settings.gap }}px;
      --recommended-images-heading-gap: {{ block_settings.heading_gap }}px;
      --recommended-images-columns: {{ grid_columns }};
      --recommended-images-columns-mobile: {{ mobile_columns }};
    "
  >
    <recommended-product-images-carousel
      class="recommended-product-images__carousel"
      data-page-count="{% if recommendations.performed or closest.product == blank %}{{ page_count }}{% else %}1{% endif %}"
      data-products-per-slide="{{ products_per_slide }}"
    >
      {%- if block_settings.show_heading and block_settings.heading != blank -%}
        <div
          class="recommended-product-header recommended-product-header--{{ block_settings.heading_alignment }}"
        >
          <div
            class="recommended-product-header__title {{ heading_class }}"
            {% if block_settings.heading_font_size != blank %}
              style="font-size: {{ block_settings.heading_font_size }};"
            {% endif %}
          >
            <span class="recommended-product-header__heading-text">{{ block_settings.heading | escape }}</span>
            <span class="recommended-product-header__count">
              {{- displayed_product_count }}
              {{ 'content.search_results_resource_products' | t -}}
            </span>
            <div class="recommended-product-images__arrows">
                <button
                  type="button"
                  class="recommended-product-images__arrow recommended-product-images__arrow--previous button button-unstyled button-unstyled--transparent"
                  ref="previousButton"
                  on:click="/previous"
                  aria-label="{{ 'accessibility.slideshow_previous' | t }}"
                  {% if page_count <= 1 %}disabled{% endif %}
                >
                <span class="svg-wrapper icon-caret icon-caret--backward">
                  {{- 'icon-caret.svg' | inline_asset_content -}}
                </span>
                </button>
                <button
                  type="button"
                  class="recommended-product-images__arrow recommended-product-images__arrow--next button button-unstyled button-unstyled--transparent"
                  ref="nextButton"
                  on:click="/next"
                  aria-label="{{ 'accessibility.slideshow_next' | t }}"
                  {% if page_count <= 1 %}disabled{% endif %}
                >
                <span class="svg-wrapper icon-caret icon-caret--forward">
                  {{- 'icon-caret.svg' | inline_asset_content -}}
                </span>
                </button>
            </div>
          </div>
        </div>
      {%- endif -%}

      {%- if recommendations.performed or closest.product == blank -%}
      {%- capture image_ratio -%}
        {%- case block_settings.image_ratio -%}
          {%- when 'landscape' -%}16 / 9
          {%- when 'portrait' -%}4 / 5
          {%- when 'square' -%}1
          {%- else -%}1
        {%- endcase -%}
      {%- endcapture -%}

        <div class="recommended-product-images__viewport">
            <div
              class="recommended-product-images__track"
              ref="track"
              style="--recommended-page-count: {{ page_count }};"
            >
              {%- for page_index in (1..page_count) -%}
                {%- assign page_offset = page_index | minus: 1 | times: products_per_slide -%}
                <div class="recommended-product-images__slide">
                  <ul
                    class="recommended-product-images__grid"
                    role="list"
                    style="
                      --recommended-images-aspect-ratio: {{ image_ratio | strip }};
                      --border-width: {{ block_settings.item_border_width }}px;
                      --border-style: {{ block_settings.item_border }};
                      --border-color: rgb(var(--color-border-rgb) / {{ block_settings.item_border_opacity | divided_by: 100.0 }});
                      --border-radius: {{ block_settings.item_border_radius }}px;
                    "
                    {% if page_index == 1 %}
                      data-has-recommendations="{% if products != blank and products.size > 0 %}true{% else %}false{% endif %}"
                    {% endif %}
                  >
                    {%- for product in products limit: products_per_slide offset: page_offset -%}
                      {%- liquid
                        assign featured_image = product.featured_media.preview_image | default: product.featured_image
                        assign item_ratio = image_ratio | strip
                        if block_settings.image_ratio == 'adapt' and featured_image != blank
                          assign item_ratio = featured_image.aspect_ratio | default: 1
                        endif
                      -%}
                      <li
                        class="recommended-product-images__item border-style"
                        style="--recommended-images-aspect-ratio: {{ item_ratio }};"
                      >
                        <a
                          class="recommended-product-images__link"
                          href="{{ product.url }}"
                          aria-label="{{ product.title | escape }}"
                        >
                          {%- if featured_image != blank -%}
                            {{
                              featured_image
                              | image_url: width: 600
                              | image_tag:
                                loading: 'lazy',
                                class: 'recommended-product-images__image',
                                widths: '165, 360, 533, 600',
                                sizes: '(min-width: 750px) 25vw, 50vw',
                                alt: featured_image.alt | default: product.title | escape
                            }}
                          {%- else -%}
                            <span class="recommended-product-images__placeholder" aria-hidden="true"></span>
                          {%- endif -%}
                        </a>
                      </li>
                    {%- endfor -%}
                  </ul>
                </div>
              {%- endfor -%}
            </div>
          </div>
      {%- else -%}
        <div class="recommended-product-images__viewport">
          <div class="recommended-product-images__track" ref="track" style="--recommended-page-count: 1;">
            <div class="recommended-product-images__slide">
              <ul
                class="recommended-product-images__grid"
                role="list"
                aria-busy="true"
                style="
                  --border-width: {{ block_settings.item_border_width }}px;
                  --border-style: {{ block_settings.item_border }};
                  --border-color: rgb(var(--color-border-rgb) / {{ block_settings.item_border_opacity | divided_by: 100.0 }});
                  --border-radius: {{ block_settings.item_border_radius }}px;
                "
              >
                {%- for i in (1..products_per_slide) -%}
                  <li
                    class="recommended-product-images__item recommended-product-images__item--skeleton border-style"
                    aria-label="{{ 'accessibility.loading_product_recommendations' | t }}"
                  ></li>
                {%- endfor -%}
              </ul>
            </div>
          </div>
        </div>
      {%- endif -%}
    </recommended-product-images-carousel>
  </div>
</product-recommendations>

{% stylesheet %}
  .recommended-product-images {
    display: block;
    width: 100%;
    min-width: 0;
  }

  .recommended-product-images__inner {
    display: flex;
    flex-direction: column;
    gap: var(--recommended-images-heading-gap, 12px);
    width: 100%;
  }

  .recommended-product-header {
    width: 100%;
  }

  .recommended-product-header--left {
    text-align: left;
  }

  .recommended-product-header--center {
    text-align: center;
  }

  .recommended-product-header--right {
    text-align: right;
  }

  .recommended-product-header__title {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5em;
    width: 100%;
    font-weight: bold !important;
    margin: 0;
  }

  .recommended-product-header--center .recommended-product-header__title {
    justify-content: center;
  }

  .recommended-product-header--right .recommended-product-header__title {
    justify-content: flex-end;
  }

  .recommended-product-header__count {
    font-weight: normal;
    opacity: 0.65;
  }

  .recommended-product-images__arrows {
    display: inline-flex;
    align-items: center;
    gap: 0.25em;
    margin-inline-start: auto;
  }

  .recommended-product-images__carousel {
    display: flex;
    flex-direction: column;
    gap: var(--recommended-images-heading-gap, 12px);
    width: 100%;
    min-width: 0;
  }

  .recommended-product-images__arrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    cursor: pointer;
    color: inherit;
    flex-shrink: 0;
  }

  .recommended-product-images__arrow:disabled {
    opacity: 0.35;
    cursor: default;
  }

  .recommended-product-images__arrow .svg-wrapper {
    width: 1em;
    height: 1em;
  }

  .recommended-product-images__viewport {
    overflow: hidden;
    width: 100%;
    min-width: 0;
  }

  .recommended-product-images__track {
    display: flex;
    width: calc(100% * var(--recommended-page-count, 1));
    transition: transform 0.35s ease;
    will-change: transform;
  }

  .recommended-product-images__slide {
    flex: 0 0 calc(100% / var(--recommended-page-count, 1));
    min-width: 0;
  }

  .recommended-product-images__grid {
    display: grid;
    grid-template-columns: repeat(var(--recommended-images-columns-mobile, 2), minmax(0, 1fr));
    gap: var(--recommended-images-gap, 12px);
    margin: 0;
    padding: 0;
    list-style: none;
  }

  @media screen and (min-width: 750px) {
    .recommended-product-images__grid {
      grid-template-columns: repeat(var(--recommended-images-columns, 4), minmax(0, 1fr));
    }
  }

  .recommended-product-images__item {
    min-width: 0;
    aspect-ratio: var(--recommended-images-aspect-ratio, 1);
    overflow: hidden;
  }

  .recommended-product-images__link {
    display: block;
    width: 100%;
    height: 100%;
    background-color: rgb(var(--color-foreground-rgb) / 0.06);
  }

  .recommended-product-images__image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .recommended-product-images__placeholder {
    display: block;
    width: 100%;
    height: 100%;
    background-color: rgb(var(--color-foreground-rgb) / 0.08);
  }

  .recommended-product-images__item--skeleton {
    aspect-ratio: 1;
    background-color: rgb(var(--color-foreground-rgb) / 0.08);
    animation: recommended-product-images-pulse 1.5s ease-in-out infinite;
  }

  @keyframes recommended-product-images-pulse {
    0%,
    100% {
      opacity: 1;
    }

    50% {
      opacity: 0.5;
    }
  }
{% endstylesheet %}

